[init]
  defaultBranch = main

[user]
	email = stevenhanselgo@gmail.com
  name = Myron

[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta

[delta]
    plus-style = "syntax #012800"
    minus-style = "syntax #340001"
    syntax-theme = Monokai Extended
    navigate = true

[interactive]
    diffFilter = delta --color-only
[credential]
	helper = osxkeychain
[url "git@github.com:"]
	insteadOf = https://github.com/
